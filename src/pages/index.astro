---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";

// IMPORTACIÓN DE IMÁGENES
import { Image } from "astro:assets";
import imgMoscas from "../assets/moscas-app.jpg";
import imgDron from "../assets/dron-app.png";
import imgMlOrange from "../assets/mlorange.png";
import imgCajaCusco from "../assets/cajacusco.png";
import imgSmartCities from "../assets/smartcities.png";
import imgQuechua from "../assets/quechua.webp";
import imgPerfil from "../assets/foto_perfil.jpg";
---

<!doctype html>
<html lang="es">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      html {
        scroll-behavior: smooth;
      }
      h1 {
        font-size: 2.2rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
        letter-spacing: -0.02em;
      }
      h2 {
        font-size: 1.5rem;
        margin-top: 3.5rem;
        margin-bottom: 1.5rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid #eaeaea;
      }
      p {
        font-size: 1rem;
        line-height: 1.7;
        color: #4a5568;
        margin-bottom: 1.2rem;
      }

      .project-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1.5rem;
        margin-bottom: 2rem;
      }
      .project-card {
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 1.2rem;
        background: #fff;
        transition:
          transform 0.2s ease,
          box-shadow 0.2s ease;
        position: relative;
      }
      .project-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.08);
      }
      .project-card img {
        border-radius: 8px;
        margin-bottom: 1rem;
        width: 100%;
        height: 180px;
        object-fit: contain;
        object-position: center;
        background-color: #f8fafc;
        display: block;
      }

      .card-link::after {
        content: "";
        position: absolute;
        top: 0;
        right: 0;
        bottom: 0;
        left: 0;
        z-index: 1;
      }

      .project-card h4 {
        font-size: 1.1rem;
        margin-top: 0;
        margin-bottom: 0.5rem;
        color: #1a202c;
      }
      .project-card p {
        font-size: 0.9rem;
        line-height: 1.5;
        margin-bottom: 1rem;
      }

      .tag {
        display: inline-block;
        background: #f1f5f9;
        color: #334155;
        padding: 0.2rem 0.7rem;
        border-radius: 20px;
        font-size: 0.75rem;
        margin-right: 0.3rem;
        margin-bottom: 0.5rem;
        font-weight: 600;
      }

      .profile-container {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        margin-bottom: 2rem;
      }
      .profile-text {
        flex: 1;
      }
      .profile-text h1 {
        margin-top: 0;
      }

      .profile-image-wrapper {
        flex: 0 0 auto;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .profile-pic {
        width: 210px !important;
        height: 210px !important;
        border-radius: 50% !important;
        object-fit: cover !important;
        border: 4px solid #f1f5f9;
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        transition: transform 0.3s ease;
        display: block;
      }
      .profile-pic:hover {
        transform: scale(1.05);
      }

      .spider-cta {
        background: #fef2f2;
        border-left: 4px solid #ef4444;
        padding: 1.2rem;
        border-radius: 6px;
        margin-bottom: 2rem;
      }
      .spider-cta p {
        margin: 0;
        font-size: 0.95rem;
        color: #991b1b;
        line-height: 1.6;
      }

      .card-actions {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 1.5rem;
        position: relative;
        z-index: 2;
      }

      .btn-github {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        color: #475569;
        font-size: 0.85rem;
        font-weight: 600;
        text-decoration: none;
        transition: color 0.2s ease;
      }
      .btn-github:hover {
        color: #000;
      }

      .btn-study {
        background: #2563eb;
        color: #ffffff !important;
        padding: 0.5rem 1rem;
        border-radius: 6px;
        font-size: 0.85rem;
        font-weight: 600;
        text-decoration: none;
        transition:
          background-color 0.2s ease,
          transform 0.2s ease;
      }
      .btn-study:hover {
        background: #1d4ed8;
        transform: translateY(-2px);
      }

      @media (max-width: 768px) {
        .profile-container {
          flex-direction: column-reverse;
          gap: 1.5rem;
          text-align: center;
        }
        .profile-pic {
          width: 160px !important;
          height: 160px !important;
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <div class="profile-container">
        <div class="profile-text">
          <h1 id="inicio">Hola, soy Erick Bustamante</h1>
          <p>
            <strong>Ingeniero de Software Full Stack & Frontend</strong>.
            Actualmente curso la <strong
              >Maestría en Informática (PPGI) en la Universidade de Brasília
              (UnB)</strong
            >, con especialización en <strong>Visión Computacional</strong>. Me
            apasiona construir aplicaciones móviles y web de alto rendimiento
            utilizando tecnologías modernas.
          </p>
          <p>
            Me enfoco en escribir código limpio, mitigar la deuda técnica y
            optimizar el rendimiento en el lado del cliente. Cuento con
            experiencia real en el sector financiero y en el desarrollo de
            software a medida, integrando hitos complejos como comunicación con
            hardware, procesamiento multimedia y modelos de Inteligencia
            Artificial.
          </p>
        </div>
        <div class="profile-image-wrapper">
          <Image src={imgPerfil} alt="Erick Bustamante" class="profile-pic" />
        </div>
      </div>

      <div class="spider-cta">
        <p>
          🕸️ <strong>¿Por qué estoy aquí?</strong> Gracias a un curso de React de
          Midudev logré un puesto como Ingeniero de Software en ML Orange. Hoy quiero
          aportar este stack y mi experiencia para que la landing de <strong
            >Spider-Man: Brand New Day</strong
          > resista los picos de tráfico.
        </p>
      </div>

      <!-- SECCIÓN 1: EXPERIENCIA -->
      <h2 id="experiencia">💼 Experiencia de Trabajo</h2>
      <div class="project-grid">
        <!-- TARJETA 1: CAJA CUSCO -->
        <div class="project-card">
          <Image src={imgCajaCusco} alt="Caja Cusco App" width={600} />
          <h4>Caja Municipal Cusco</h4>
          <div>
            <span class="tag">Kotlin</span>
            <span class="tag">Spring Boot</span>
            <span class="tag">SQL Server</span>
          </div>
          <p>
            Desarrollo del aplicativo móvil Wayki App. Implementación de nuevas
            funcionalidades y optimización de recursos en la banca digital.
          </p>
          <a
            href="https://play.google.com/store/apps/details?id=com.pe.cajacusco.movil&hl=es"
            target="_blank"
            class="card-link"
            style="font-size: 0.9rem; font-weight: bold; color: #2563eb;"
            >Ver Aplicacion en Play Store &rarr;</a
          >
        </div>

        <!-- TARJETA 2: ML ORANGE -->
        <div class="project-card">
          <Image src={imgMlOrange} alt="ML Orange App" width={600} />
          <h4>ML Orange (XMachina)</h4>
          <div>
            <span class="tag">React Native</span>
            <span class="tag">React</span>
            <span class="tag">Express</span>
          </div>
          <p>
            Desarrollo Full Stack de un aplicativo móvil para el análisis de
            audios y prediccion de enfermedades en los trabajadores y soporte de
            módulos en el aplicativo de escritorio para el control de
            informaciòn (Electron).
          </p>
          <a
            href="https://www.linkedin.com/company/ex-machina-si/posts/?feedView=all"
            target="_blank"
            class="card-link"
            style="font-size: 0.9rem; font-weight: bold; color: #2563eb;"
            >Ver perfil en Linkedin &rarr;</a
          >
        </div>

        <!-- TARJETA 3: SMART CITIES -->
        <div class="project-card">
          <Image src={imgSmartCities} alt="Smart Cities" width={600} />
          <h4>Smart Cities Perú</h4>
          <div>
            <span class="tag">Angular</span>
            <span class="tag">JavaScript</span>
            <span class="tag">Figma</span>
          </div>
          <p>
            Refactorización completa de sistemas Extranet e Intranet de la
            empresa Consettur. Desarrollo de interfaz gráfica para el ERP médico
            de la Clínica Macsalud.
          </p>
          <a
            href="https://www.linkedin.com/company/smart-cities-peru-sac/posts/?feedView=all"
            target="_blank"
            class="card-link"
            style="font-size: 0.9rem; font-weight: bold; color: #2563eb;"
            >Ver perfil en Linkedin &rarr;</a
          >
        </div>
      </div>

      <!-- SECCIÓN 2: PROYECTOS INDEPENDIENTES Y ACADÉMICOS -->
      <h2 id="proyectos">🛠️ Proyectos Independientes</h2>
      <div class="project-grid">
        <!-- WEB CLASIFICACIÓN MOSCAS-->
        <div class="project-card">
          <a href="/caso-moscas" class="card-link">
            <Image src={imgMoscas} alt="Clasificador Moscas" width={600} />
          </a>

          <h4>Web de Clasificación con IA</h4>
          <div class="tag-container" style="margin-bottom: 0.5rem;">
            <span class="tag">React</span>
            <span class="tag">Flask</span>
            <span class="tag">Computer Vision</span>
          </div>
          <p>
            Aplicación web Full Stack para cargar imágenes y clasificar especies
            de mosca de la fruta. Prototipo de tesis propio.
          </p>

          <div class="card-actions">
            <a
              href="/caso-moscas"
              style="font-size: 0.9rem; font-weight: bold; color: #16a34a;"
              class="btn-study"
            >
              Caso de Estudio &rarr;
            </a>
            <a href="TU_LINK_DE_GITHUB_AQUI" target="_blank" class="btn-github">
              <svg
                viewBox="0 0 16 16"
                aria-hidden="true"
                width="18"
                height="18"
              >
                <path
                  fill="currentColor"
                  d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
                ></path>
              </svg>
              GitHub
            </a>
          </div>
        </div>

        <!-- APP DRON-->
        <div class="project-card">
          <Image src={imgDron} alt="App Dron Kotlin" width={600} />
          <h4>Control de Dron Nativo</h4>
          <div>
            <span class="tag">Kotlin</span>
            <span class="tag">DJI SDK</span>
          </div>
          <p>
            App Android para control de drones y procesamiento de video en
            tiempo real para detección de llamas y alpacas con Inteligencia
            Artificial.
          </p>
          <a
            href="/caso-dron"
            class="card-link"
            style="font-size: 0.9rem; font-weight: bold; color: #16a34a;"
            >Ver Caso de Estudio &rarr;</a
          >
        </div>

        <!-- APP QUECHUA-->
        <div class="project-card">
          <Image src={imgQuechua} alt="App Quechua" width={600} />
          <h4>Recolección de Audio en Quechua</h4>
          <div>
            <span class="tag">Java</span>
            <span class="tag">Android</span>
            <span class="tag">FastAPI</span>
            <span class="tag">PostgreSQL</span>
            <span class="tag">MinIO (S3)</span>
            <span class="tag">Audio API</span>
          </div>
          <p>
            App móvil desarrollada para una tesis externa orientada a la
            recolección y estructuración de datos de voz en lenguas indígenas
            para la creaciòn de datasets para modelos predictivos.
          </p>
          <a
            href="/caso-quechua"
            class="card-link"
            style="font-size: 0.9rem; font-weight: bold; color: #16a34a;"
            >Ver Caso de Estudio &rarr;</a
          >
        </div>
      </div>
    </main>
    <Footer />
  </body>
</html>
